#!/system/bin/sh

# Realme UI Tweaks - Main Controller
# Usage: realme-tweaks [module] [action]

MODULES_DIR="/system/bin/modules"
LOG_FILE="/data/local/tmp/realme_tweaks.log"

log_msg() {
echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" >> $LOG_FILE
}

list_modules() {
echo "Available modules:"
for module in $MODULES_DIR/*.sh; do
basename "$module" .sh
done
}

run_module() {
local module_name="$1"
local module_path="$MODULES_DIR/${module_name}.sh"

if [ -f "$module_path" ]; then
log_msg "▶️ Running module: $module_name"
sh "$module_path"
log_msg "✅ Module completed: $module_name"
else
echo "❌ Module not found: $module_name"
return 1
fi
}

status() {
echo "═══════════════════════════════════════════════"
echo " 📊 Realme UI Tweaks - Status"
echo "═══════════════════════════════════════════════"
echo ""
echo "Active Modules:"
for module in $MODULES_DIR/*.sh; do
if [ -f "$module" ] && [ "$(basename $module)" != "module_loader.sh" ]; then
name=$(basename "$module" .sh)
if grep -q "✅ Module completed: $name" $LOG_FILE 2>/dev/null; then
echo " ✅ Active $name"
else
echo " ⏳ Inactive $name"
fi
fi
done
echo ""
echo "📄 Log: $LOG_FILE"
echo "═══════════════════════════════════════════════"
}

case "$1" in
list)
list_modules
;;
run)
if [ -z "$2" ]; then
echo "Usage: realme-tweaks run <module_name>"
  echo "Modules: $(list_modules | grep -v 'Available' | tr '\n' ' ')"
  exit 1
  fi
  run_module "$2"
  ;;
  status)
  status
  ;;
  *)
  echo "Realme UI Tweaks - Main Controller"
  echo ""
  echo "Usage:"
  echo " realme-tweaks list - Show all modules"
  echo " realme-tweaks run <module> - Run specific module"
    echo " realme-tweaks status - Show status"
    echo ""
    ;;
    esac